[gd_scene load_steps=2 format=3 uid="uid://deeprootuilayer"]

[ext_resource type="Script" path="res://scenes/ui_layer.gd" id="1_ui"]

[node name="UILayer" type="CanvasLayer"]
script = ExtResource("1_ui")

; ═══════════════════════════════════════════════════════════════
; HUD Panel — top-left, 280px wide
; ═══════════════════════════════════════════════════════════════
[node name="HUD_Panel" type="Panel" parent="."]
offset_left = 4.0
offset_top = 4.0
offset_right = 284.0
offset_bottom = 4.0
mouse_filter = 1

[node name="HUD_Margin" type="MarginContainer" parent="HUD_Panel"]
